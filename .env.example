NEXT_PUBLIC_API_BASE_URL="https://deframe-picn-papais-brl-brpga0.herokuapp.com"

# Local-only customer simulator. This Next.js app acts like the customer's
# backend during demos: it owns Sumsub, receives webhooks, then calls Pods.
PODS_KYC_API_BASE_URL="https://deframe-picn-papais-brl-brpga0.herokuapp.com"
PODS_KYC_API_KEY="kyc_test_change-me"

# Optional Swap v2 callback for local test observation. The parameter name sent
# to Pods is webhookURL. Do not place a production endpoint in this example.
NEXT_PUBLIC_DEMO_SWAP_WEBHOOK_URL=""

SUMSUB_API_BASE_URL="https://api.sumsub.com"
SUMSUB_ENVIRONMENT="sandbox"
SUMSUB_APP_TOKEN="change-me"
SUMSUB_SECRET_KEY="change-me"
SUMSUB_SANDBOX_APP_TOKEN="change-me"
SUMSUB_SANDBOX_SECRET_KEY="change-me"
SUMSUB_PRODUCTION_APP_TOKEN="change-me"
SUMSUB_PRODUCTION_SECRET_KEY="change-me"
SUMSUB_LEVEL_NAME="pods-kyc-level"
SUMSUB_WEBHOOK_SECRET="change-me"
SUMSUB_SANDBOX_WEBHOOK_SECRET="change-me"
# Optional comma-separated extra secrets for webhook secret rotation.
SUMSUB_WEBHOOK_SECRETS=""

# Provided by Pods/Avenia during customer onboarding.
AVENIA_FOR_CLIENT_ID="change-me"
